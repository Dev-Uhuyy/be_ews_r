    {
      "name": "10 - Dekan Dashboard",
      "item": [
        {
          "name": "Dashboard Overview",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }] },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{api_base}}/ews/dekan/dashboard",
              "host": ["{{api_base}}"],
              "path": ["ews", "dekan", "dashboard"]
            },
            "description": "Mengambil data dashboard dekan: statistik global, rata IPK per tahun, statistik kelulusan, tabel ringkasan per prodi"
          }
        },
        {
          "name": "Dashboard Detail per Prodi & Tahun",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }] },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{api_base}}/ews/dekan/dashboard/detail?prodi_id={{prodi_id}}",
              "host": ["{{api_base}}"],
              "path": ["ews", "dekan", "dashboard", "detail"],
              "query": [{ "key": "prodi_id", "value": "{{prodi_id}}" }]
            },
            "description": "Detail data per prodi dan tahun angkatan: jumlah mahasiswa, aktif, cuti 2x, IPK rata-rata, tepat waktu, perhatian, kritis"
          }
        },
        {
          "name": "List Mahasiswa by Kriteria",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }] },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{api_base}}/ews/dekan/dashboard/mahasiswa?prodi_id={{prodi_id}}&tahun_masuk={{tahun_masuk}}&criteria=aktif",
              "host": ["{{api_base}}"],
              "path": ["ews", "dekan", "dashboard", "mahasiswa"],
              "query": [
                { "key": "prodi_id", "value": "{{prodi_id}}" },
                { "key": "tahun_masuk", "value": "{{tahun_masuk}}" },
                { "key": "criteria", "value": "aktif" }
              ]
            },
            "description": "List mahasiswa dengan filter. Kriteria: aktif, cuti_2x, tepat_waktu, perhatian, kritis"
          }
        }
      ]
    },
